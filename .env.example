# Client-side environment variables (safe to expose via Vite bundle).
# Copy this file to .env and fill in your values.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend secrets (SERVICE_ROLE_KEY, CLAUDE_API_KEY, OPENAI_API_KEY,
# RESEND_API_KEY, MOYASAR_API_KEY, etc.) must NOT go here.
# Copy .env.backend.example (or see .env.backend) and manage those
# values via Supabase dashboard / Edge Function secrets.
